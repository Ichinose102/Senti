# Discord Configuration
DISCORD_TOKEN=votre_token_discord
CLIENT_ID=votre_client_id
GUILD_ID=votre_guild_id

# Twitch API Configuration
# Obtenir sur https://dev.twitch.tv/console
TWITCH_CLIENT_ID=votre_client_id_twitch
TWITCH_ACCESS_TOKEN=votre_access_token_twitch

# Pour obtenir le token d'accès Twitch, exécutez cette commande dans un terminal :
# curl -X POST 'https://id.twitch.tv/oauth2/token' \
#   -d 'client_id=VOTRE_CLIENT_ID' \
#   -d 'client_secret=VOTRE_CLIENT_SECRET' \
#   -d 'grant_type=client_credentials'

# TikTok RSS Configuration (optionnel)
# S'inscrire sur https://rss.app pour obtenir une clé API
RSS_APP_API_KEY=votre_cle_api_rss_app
